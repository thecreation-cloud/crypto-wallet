{
  "name": "crypto-wallet",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @wallet/web dev",
    "dev:desktop": "pnpm --filter @wallet/desktop dev",
    "dev:mobile": "pnpm --filter @wallet/mobile start",
    "build:desktop": "pnpm --filter @wallet/desktop build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
