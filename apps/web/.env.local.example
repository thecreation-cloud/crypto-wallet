# Copy to .env.local and fill in your RPC endpoints.
# All entries below have free public fallbacks built in — only override if you want
# private/higher-rate-limit RPCs (Infura, Alchemy, QuickNode, etc.)

# EVM chains
NEXT_PUBLIC_ETH_RPC_URL=https://cloudflare-eth.com
NEXT_PUBLIC_BNB_RPC_URL=https://bsc-dataseed.binance.org
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
NEXT_PUBLIC_AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
NEXT_PUBLIC_ARB_RPC_URL=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_OP_RPC_URL=https://mainnet.optimism.io
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_FTM_RPC_URL=https://rpc.ftm.tools
NEXT_PUBLIC_ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
NEXT_PUBLIC_CRO_RPC_URL=https://evm.cronos.org
NEXT_PUBLIC_GNO_RPC_URL=https://rpc.gnosischain.com
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Non-EVM chains
NEXT_PUBLIC_SOL_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_XRP_RPC_URL=wss://xrplcluster.com
NEXT_PUBLIC_NEAR_RPC_URL=https://rpc.mainnet.near.org
NEXT_PUBLIC_TRON_API_KEY=   # Get free key at trongrid.io
